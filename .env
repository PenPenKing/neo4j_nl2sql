# ==========================================
# 1. Neo4j 数据库配置
# ==========================================
# 如果是本地安装版，默认地址通常是 bolt://localhost:7687
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j123

# ==========================================
# 2. Ollama 本地模型配置
# ==========================================
# Ollama 默认监听 11434 端口
OLLAMA_BASE_URL=http://localhost:11434
# 填入你之前用 ollama create 构建的模型全名
LLM_MODEL=qwen3:4b

# ==========================================
# 3. Agent 策略配置 (核心控制参数)
# ==========================================
# 最大反思重试次数，设为 3 比较稳健
MAX_RETRIES=3
# LLM 的采样温度，Cypher 生成建议设为 0，保证代码严谨、不乱发挥
LLM_TEMPERATURE=0
# 混合 RAG 召回的 Top-K 数量
RAG_TOP_K=2

# ==========================================
# 4. 日志级别 (演示时建议设为 INFO 或 DEBUG)
# ==========================================
LOG_LEVEL=INFO